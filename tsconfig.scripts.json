{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist/scripts"
  },
  "include": ["scripts/**/*.ts"],
  "ts-node": {
    "esm": false,
    "transpileOnly": true
  }
}
